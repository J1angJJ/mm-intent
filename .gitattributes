# Normalize text files across Windows, macOS, and Linux.
* text=auto

# Source and documentation stay LF in the repository.
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.ipynb text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.sh text eol=lf
*.tex text eol=lf
*.bib text eol=lf

# Windows scripts should keep CRLF for native tools.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Treat common binary assets and ML artifacts as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.doc binary
*.docx binary
*.ppt binary
*.pptx binary
*.xls binary
*.xlsx binary
*.zip binary
*.7z binary
*.rar binary
*.tar binary
*.gz binary
*.tgz binary
*.mp3 binary
*.wav binary
*.mp4 binary
*.mov binary
*.avi binary
*.npy binary
*.npz binary
*.pt binary
*.pth binary
*.ckpt binary
*.pkl binary
*.pickle binary
*.joblib binary
*.woff binary
*.woff2 binary
